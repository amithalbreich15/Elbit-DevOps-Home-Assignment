# RabbitMQ connection
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=root
RABBITMQ_PASS=change_me_do_not_commit_real_password

# Queue configuration
QUEUE_NAME=ABC
DLQ_NAME=ABC.dlq

# Publisher settings
NUM_MESSAGES=10
MESSAGE_DELAY=0.5

# Retry settings
MAX_RETRIES=5
RETRY_BACKOFF=2.0

# Consumer settings
PREFETCH_COUNT=1
