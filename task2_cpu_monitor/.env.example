# ══════════════════════════════════════════════════════════════════════════════
# Task 2 – Environment Configuration
# Copy to .env and edit before running docker compose.
#
# IMPORTANT:
#   - This file is safe to commit (no real secrets inside).
#   - Actual secrets (smtp_pass, alert_to) go into secrets/ files.
#   - .gitignore already excludes secrets/ and .env
# ══════════════════════════════════════════════════════════════════════════════

# ── CPU Monitor ───────────────────────────────────────────────────────────────
# Low threshold for testing – raise to 80 for production
CPU_THRESHOLD=80
CHECK_INTERVAL=5
METRICS_PORT=8000

# ── Stress client ─────────────────────────────────────────────────────────────
STRESS_DURATION=30   # seconds of CPU stress per cycle
IDLE_DURATION=20     # seconds of idle per cycle
CPU_WORKERS=2        # parallel stress workers

# ── SMTP (non-secret part) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
ALERT_FROM=your_gmail_address@gmail.com
# SMTP_PASS  →  put in secrets/smtp_pass
# ALERT_TO   →  put in secrets/alert_to

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme   # change this for any non-local deployment
