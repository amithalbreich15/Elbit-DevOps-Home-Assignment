{
  "uid": "cpu-monitor-task2",
  "title": "CPU Monitor – Task 2 (Elbit DevOps)",
  "tags": ["devops", "cpu", "task2"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Current CPU Usage",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red",    "value": 20 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "cpu_usage_percent",
        "legendFormat": "CPU %"
      }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage Over Time",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "red",    "value": 20 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend":  { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "cpu_usage_percent",
          "legendFormat": "CPU Usage %"
        },
        {
          "datasource": "Prometheus",
          "expr": "20",
          "legendFormat": "Alert Threshold (20%)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Alerts Fired",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "cpu_alerts_total",
        "legendFormat": "Alerts"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Configured Threshold",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "20",
        "legendFormat": "Threshold"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Alert Rate (alerts per minute)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(cpu_alerts_total[1m]) * 60",
        "legendFormat": "Alerts/min"
      }]
    }
  ]
}
